# ==========================================
# 1. Выходные файлы компиляции и сборки
# ==========================================
# Объектные файлы и зависимости
*.o
*.obj
*.d
*.slo
*.lo

# Статические и динамические библиотеки
*.a
*.lib
*.la
*.lai
*.so
*.so.*
*.dylib
*.dll

# Исполняемые файлы
*.exe
*.out
*.app

# Предкомпилированные заголовки и дебаг
*.gch
*.pch
*.dwo
*.pdb
*.ilk

# Fortran (если вдруг занесет)
*.mod
*.smod

# ==========================================
# 2. Директории сборки (Build & Cache)
# ==========================================
build/
Build/
build-*/
.cache/
vcpkg_installed/

# Если CMake вдруг запущен в корне (in-source build)
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
Testing/

# ==========================================
# 3. Временные файлы и логи
# ==========================================
*.tmp
*.log
*.bak
*.swp
*~

# ==========================================
# 4. Специфика IDE и ОС
# ==========================================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# CLion / JetBrains
.idea/
*.iws

# Специфика Linux (KDE Dolphin и др.)
.directory
.DS_Store

# Файлы профилирования
gmon.out
*.profraw

# ==========================================
# 5. Конфиденциальность и инструменты
# ==========================================
# Переменные окружения (Критично!)
.env
.env.local
.env.*.local

# Архивы и дистрибутивы
*.tar
*.tar.gz
*.zip
*.7z

# Базы данных и локальный кэш инструментов
.clangd/
.cache/

# Инструменты форматирования:
# Мы форсированно НЕ игнорируем конфиги, чтобы они были в Git
!.clang-format
!.clang-tidy

# JS-инструменты (если появятся для доков или инструментов)
node_modules/

# ==========================================
# 6. Дополнительные языки и скрипты
# ==========================================
# Python
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 7. Графика и ресурсы (Специфика проекта)
# ==========================================
# Временные файлы редакторов графики
*.autosave
*.bak
